<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="LOG_FILE" source="logging.file.name" defaultValue="logs/fulfillment-agent.log"/>
    <springProperty name="LOG_FILE_MAX_SIZE" source="logging.file.max-size" defaultValue="10MB"/>
    <springProperty name="LOG_FILE_MAX_HISTORY" source="logging.file.max-history" defaultValue="10"/>
    <springProperty name="SPRING_APPLICATION_NAME" source="spring.application.name" defaultValue="fulfillment-agent"/>

    <!-- Console Appender (structured JSON via logstash-logback-encoder) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <customFields>{"serviceName":"${SPRING_APPLICATION_NAME}"}</customFields>
        </encoder>
    </appender>

    <!-- File Appender (JSON format for production / Google Cloud Logging) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/fulfillment-agent-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
            <maxHistory>${LOG_FILE_MAX_HISTORY}</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>requestId</includeMdcKeyName>
            <customFields>{"serviceName":"${SPRING_APPLICATION_NAME}","environment":"${ENVIRONMENT:local}"}</customFields>
        </encoder>
    </appender>

    <!-- Async Appender for better performance -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- Spring Boot Default Logback Configuration -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Logger Configuration -->
    <logger name="com.equifax.ews.vs.ici" level="DEBUG"/>
    <logger name="com.google.cloud" level="INFO"/>
    <logger name="org.springframework.web" level="DEBUG"/>
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.cloud" level="INFO"/>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </root>

    <!-- Production Profile: JSON only, no file -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>